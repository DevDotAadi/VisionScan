# ==============================================================================
# VisionScan Global — Environment Configuration Template
# Copy this file to `.env` and fill in your keys. Do NOT commit `.env` to Git!
# ==============================================================================

# Google Gemini API Key (Obtain from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Rate Limiting & Safety Controls
GEMINI_MAX_REQUESTS_PER_SESSION=20
GEMINI_MAX_REQUESTS_PER_MINUTE=5
MAX_UPLOAD_MB=10
MAX_BATCH_IMAGES=500
